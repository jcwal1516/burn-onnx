{"run_id":"1772428401-955381289","line":121,"new":{"module_name":"burn_onnx__burn__node__det__tests","snapshot_name":"det_2d_forward","metadata":{"source":"crates/burn-onnx/src/burn/node/det.rs","assertion_line":121,"expression":"code"},"snapshot":"pub fn forward(&self, input: Tensor<B, 2>) -> Tensor<B, 1> {\n    let output = {\n        let (lu_mat, permutations) = burn::tensor::linalg::lu_decomposition(input);\n        let det_u = burn::tensor::linalg::diag::<B, 2usize, 1usize, Float>(lu_mat)\n            .prod();\n        let n = permutations.dims()[0];\n        let perm_f = permutations.float();\n        let perm_col = perm_f.clone().reshape([n, 1]);\n        let perm_row = perm_f.reshape([1, n]);\n        let inv_count = (perm_row - perm_col).triu(1i64).lower_elem(0.0f32).int().sum();\n        let parity = inv_count.remainder_scalar(2i64);\n        let device = det_u.device();\n        let dtype = det_u.dtype();\n        let sign = Tensor::<\n            B,\n            1,\n            Float,\n        >::from_data_dtype([1.0f32, -1.0f32], &device, dtype)\n            .select(0, parity);\n        det_u * sign\n    };\n    output\n}"},"old":{"module_name":"burn_onnx__burn__node__det__tests","metadata":{},"snapshot":"pub fn forward(&self, input: Tensor<B, 2>) -> Tensor<B, 1> {\n    let output = {\n        let (lu_mat, permutations) = burn::tensor::linalg::lu_decomposition(input);\n        let det_u =\n            burn::tensor::linalg::diag::<B, 2usize, 1usize, Float>(lu_mat).prod();\n        let n = permutations.dims()[0];\n        let perm_f = permutations.float();\n        let perm_col = perm_f.clone().reshape([n, 1]);\n        let perm_row = perm_f.reshape([1, n]);\n        let inv_count = (perm_row - perm_col).triu(1i64).lower_elem(0.0f32).int().sum();\n        let parity = inv_count.remainder_scalar(2i64);\n        let device = det_u.device();\n        let dtype = det_u.dtype();\n        let sign =\n            Tensor::<B, 1, Float>::from_data_dtype([1.0f32, -1.0f32], &device, dtype)\n                .select(0, parity);\n        det_u * sign\n    };\n    output\n}"}}
